# ============================================================
# 飲食店マーケティングOS — 環境変数サンプル
# このファイルを .env にコピーして値を設定してください。
#   cp .env.example .env
# ============================================================

# ------------------------------------------------------------
# データベース（Supabase / PostgreSQL）
# Supabase ダッシュボード > Project Settings > Database から取得
# ------------------------------------------------------------
# アプリからの通常接続（コネクションプーラー経由 / port 6543）
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Prisma のマイグレーション用の直結（port 5432）
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ------------------------------------------------------------
# Supabase（クライアント / 認証 / ストレージ）
# Supabase ダッシュボード > Project Settings > API から取得
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[ANON_KEY]"
# サーバー専用。フロントエンドには絶対に露出しないこと（NEXT_PUBLIC_ を付けない）
SUPABASE_SERVICE_ROLE_KEY="[SERVICE_ROLE_KEY]"

# ------------------------------------------------------------
# アプリ設定
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="飲食店マーケティングOS"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ------------------------------------------------------------
# AI 連携（Phase 3 / 任意）
# いずれかを設定。未設定の場合 AI 機能はモック動作。
# 生成結果は必ず人間が編集・承認してから保存する設計とする。
# ------------------------------------------------------------
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_PROVIDER="anthropic"   # anthropic | openai | mock

# ------------------------------------------------------------
# ファイルアップロード制限（任意 / 既定値はコード内定数）
# ------------------------------------------------------------
# MAX_UPLOAD_MB="10"
