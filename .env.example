# =====================================================================
# ABENGERS KNOWLEDGE OS - 環境変数サンプル
# =====================================================================
# このファイルを .env.local にコピーして利用してください。
# AI API を未設定でも、AI 以外の主要機能はすべて動作します。
# =====================================================================

# --- データソース ---------------------------------------------------
# "seed"     : 内蔵のシードデータ(インメモリ)で起動。外部DB不要で即起動。
# "supabase" : Supabase(PostgreSQL + RLS)を利用(本番想定)。
DATA_SOURCE=seed

# --- 認証 -----------------------------------------------------------
# セッション署名用シークレット(本番では必ず変更)。
AUTH_SECRET=change-me-in-production-please-32chars

# --- AI プロバイダー -------------------------------------------------
# "mock"      : AIをモック動作。API不要でRAG/要約/分類のデモが可能。
# "openai"    : OpenAI API を利用。
# "anthropic" : Anthropic API を利用。
# "gemini"    : Google Gemini API を利用。
AI_PROVIDER=mock

# 各プロバイダーの API キー(AI_PROVIDER に応じて設定)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# 埋め込み(セマンティック検索)モデル
EMBEDDING_MODEL=text-embedding-3-small

# --- Supabase(DATA_SOURCE=supabase のとき) -------------------------
NEXT_PUBLIC_SUPABASE_URL=

# 新形式 API キー(推奨)
#   publishable: sb_publishable_... (anon 相当・クライアント公開可)
#   secret     : sb_secret_...      (service_role 相当・サーバー専用/秘匿)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# 従来形式(後方互換。新形式が未設定のときのみ使用される)
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=
#   SUPABASE_SERVICE_ROLE_KEY=

# --- アップロード制限 -----------------------------------------------
MAX_UPLOAD_MB=20
